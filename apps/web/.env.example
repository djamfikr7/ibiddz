# ============================================
# iBidDZ Web Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# --- API Configuration ---
# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket/Socket.io URL for real-time features (auctions, bidding)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Next.js ---
# Node environment (development | production)
NODE_ENV=development

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# --- i18n ---
# Default locale
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Supported locales (comma-separated)
NEXT_PUBLIC_SUPPORTED_LOCALES=ar,fr,en

# --- Feature Flags ---
# Enable real-time bidding via WebSocket
NEXT_PUBLIC_ENABLE_WEBSOCKETS=true

# Enable push notifications
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false

# Enable image optimization
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true

# --- CDN / Storage ---
# Cloudinary cloud name for image uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Upload preset name (unsigned)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=ibiddz-uploads

# --- Payment Gateway ---
# Payment provider (stripe | cib | edahabia | mock)
NEXT_PUBLIC_PAYMENT_PROVIDER=mock

# --- SMS Verification ---
# Enable phone verification
NEXT_PUBLIC_ENABLE_PHONE_VERIFICATION=true

# --- Cache ---
# Revalidation time for ISR (in seconds)
NEXT_PUBLIC_REVALIDATE_SECONDS=60
