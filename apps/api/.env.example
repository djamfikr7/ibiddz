# ============================================
# iBidDZ API Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Application ---
# Node environment (development | production | test)
NODE_ENV=development

# Application port
PORT=3001

# API URL prefix
API_PREFIX=v1

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Database ---
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://ibiddz:ibiddz_dev@localhost:5432/ibiddz?schema=public

# --- Redis ---
# Redis connection URL
REDIS_URL=redis://localhost:6379

# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# --- JWT Authentication ---
# Secret key for signing JWT tokens (use a strong random string in production)
JWT_SECRET=ibiddz-development-secret-change-in-production

# Access token expiration time
JWT_ACCESS_EXPIRY=15m

# Refresh token expiration time
JWT_REFRESH_EXPIRY=7d

# JWT issuer
JWT_ISSUER=ibiddz

# JWT audience
JWT_AUDIENCE=ibiddz-users

# --- Rate Limiting ---
# Time window for rate limiting (in milliseconds)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# --- File Upload ---
# Maximum file size in bytes (default: 5MB)
MAX_FILE_SIZE=5242880

# Upload directory
UPLOAD_DIR=./uploads

# --- Socket.io ---
# Redis URL for Socket.io adapter (enables multi-instance support)
SOCKET_REDIS_URL=redis://localhost:6379

# --- BullMQ (Job Queue) ---
# Redis URL for BullMQ queues
BULL_REDIS_URL=redis://localhost:6379

# --- Cloudinary (Image Storage - Free Tier) ---
# Cloudinary cloud name (from dashboard)
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key
CLOUDINARY_API_KEY=your-api-key

# Cloudinary API secret
CLOUDINARY_API_SECRET=your-api-secret

# --- Payment Gateway (CIB/EDAHABIA) ---
# Payment API endpoint
PAYMENT_API_URL=https://api.payment-provider.dz/v1

# Payment API key
PAYMENT_API_KEY=your-payment-api-key

# --- SMS Provider (for OTP) ---
# SMS API endpoint
SMS_API_URL=https://api.sms-provider.com/v1

# SMS API key
SMS_API_KEY=your-sms-api-key

# SMS sender ID displayed to recipients
SMS_SENDER_ID=iBidDZ

# --- Logging ---
# Log level (error | warn | info | debug | verbose)
LOG_LEVEL=debug

# Log format (pretty | json)
LOG_FORMAT=pretty
